# NetMonitor Frontend Environment Variables
# Mode can be 'real' (connects to Express/WebSockets) or 'mock' (standalone client simulation)
VITE_API_MODE=real
VITE_API_URL=http://localhost:3000/api
VITE_WS_URL=ws://localhost:3000


